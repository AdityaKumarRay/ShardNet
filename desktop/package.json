{
  "name": "shardnet-desktop",
  "version": "0.1.0",
  "description": "ShardNet desktop client",
  "homepage": "https://github.com/AdityaKumarRay/ShardNet",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdityaKumarRay/ShardNet.git"
  },
  "author": {
    "name": "Aditya Kumar Ray",
    "email": "adityakumarray@users.noreply.github.com"
  },
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.shardnet.desktop",
    "productName": "ShardNet Desktop",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "Aditya Kumar Ray <adityakumarray@users.noreply.github.com>"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
